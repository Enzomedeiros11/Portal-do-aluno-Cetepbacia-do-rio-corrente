{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data including academic records and status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "grade": { "type": "string" },
        "course": { "type": "string" },
        "avatar": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "subjectGrades": { 
          "type": "object",
          "description": "Map of subject name to grades"
        }
      },
      "required": ["email", "name", "role"]
    },
    "Message": {
      "title": "Classroom Message",
      "description": "A message sent in the classroom mural",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "course": { "type": "string", "description": "Course this message belongs to" }
      },
      "required": ["senderId", "senderName", "content", "timestamp", "course"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User collection indexed by user ID"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global messages collection"
    }
  }
}
